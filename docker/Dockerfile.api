FROM python:3.11-slim

WORKDIR /app

# System deps for psycopg2, Azure SDK, pdf processing
RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    libgomp1 \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY app/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY app/ ./app/

EXPOSE 8000

# Run Member 1's FastAPI app from app/api/azure_api.py
CMD ["uvicorn", "app.api.azure_api:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
