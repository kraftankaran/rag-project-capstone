# ─────────────────────────────────────────────────────────────────────────────
# .env.template — Intelligent Document Explorer
# Owner: Karan (Member 4 — DevOps)
#
# Variable names MUST match app/core/config.py exactly (Member 1's file)
# Copy to .env, fill values. NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Used by: app/db/db.py → get_connection()
# Format:  postgresql://user:password@host:port/dbname
# Inside Docker, host = "db" (the service name in docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=doc_explorer
DATABASE_URL=postgresql://postgres:postgres@db:5432/doc_explorer

# ── Azure Service Principal Auth ──────────────────────────────────────────────
# Used by: app/core/config.py → DefaultAzureCredential()
# Used by: storage_service.py, ocr_service.py
AZURE_CLIENT_ID=your_azure_client_id
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_SECRET=your_azure_client_secret

# ── Azure Storage ─────────────────────────────────────────────────────────────
# Used by: app/services/storage_service.py
# AZURE_STORAGE_ACCOUNT = just the account name (no URL)
AZURE_STORAGE_ACCOUNT=your_storage_account_name
AZURE_STORAGE_CONTAINER=rag-documents

# ── Azure Document Intelligence (OCR) ────────────────────────────────────────
# Used by: app/services/ocr_service.py
AZURE_DOC_INTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# ── OpenAI (for Member 2 — Farhan's embeddings + RAG) ────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── App Config ────────────────────────────────────────────────────────────────
# Used by: app/core/config.py
ENV=dev
DEBUG=true

# ── API URL (for Streamlit frontend to call FastAPI) ─────────────────────────
# Used by: app/main.py (Member 3's Streamlit UI)
API_BASE_URL=http://api:8000
